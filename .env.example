# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required for LLM enrichment (executive summary + gap narratives)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: protect the REST API with a bearer token
# If unset, the API runs without authentication (suitable for local use only)
AUDITOR_API_KEY=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
